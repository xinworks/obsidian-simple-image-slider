{
  "name": "obsidian-simple-image-slider",
  "version": "0.1.0",
  "description": "A lightweight Obsidian image slider and caption renderer for image embeds.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "node --no-warnings --experimental-strip-types --test test/*.test.ts test/*.test.mjs",
    "verify": "npm run test && npm run build"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "image-slider",
    "caption"
  ],
  "author": "XIN",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.0",
    "obsidian": "^1.10.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
